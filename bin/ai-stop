#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
#  ai-stop — 메모리에 올라간 모델 내리기 (Ollama unload + MLX 프로세스 정리)
# ─────────────────────────────────────────────────────────────────────────────
#  하는 일:
#   1) `ollama ps` 로 로드된 모든 모델 → `ollama stop` 으로 언로드
#   2) 떠 있는 mlx_lm generate/chat/server 프로세스 종료
#   3) (옵션 --server) 'ollama serve' 자체도 종료
#
#  Usage:
#    ai-stop                 # 모델만 메모리에서 내림 (서버는 유지)
#    ai-stop <모델명>         # 특정 모델만 내림 (예: ai-stop solar-pro)
#    ai-stop --server        # 모델 + Ollama 서버까지 종료
#    ai-stop --all           # --server 와 동일
# ─────────────────────────────────────────────────────────────────────────────
set -e

stop_ollama_models() {
  local target="$1"
  if ! command -v ollama >/dev/null; then
    echo "  (ollama 없음 — 건너뜀)"
    return
  fi

  local running
  running=$(ollama ps 2>/dev/null | awk 'NR>1 {print $1}')
  if [[ -z "$running" ]]; then
    echo "  ✓ Ollama: 로드된 모델 없음"
    return
  fi

  while IFS= read -r model; do
    [[ -z "$model" ]] && continue
    if [[ -n "$target" && "$model" != "$target"* ]]; then
      continue
    fi
    printf "  ↓ 언로드: %s ... " "$model"
    if ollama stop "$model" >/dev/null 2>&1; then
      echo "✓"
    else
      echo "✗ (실패)"
    fi
  done <<<"$running"
}

stop_mlx_processes() {
  local pids
  pids=$(pgrep -f "mlx_lm (generate|chat|server)" 2>/dev/null || true)
  if [[ -z "$pids" ]]; then
    echo "  ✓ MLX: 실행 중인 프로세스 없음"
    return
  fi
  for pid in $pids; do
    printf "  ↓ MLX 프로세스 종료: PID %s ... " "$pid"
    if kill "$pid" 2>/dev/null; then
      echo "✓"
    else
      echo "✗"
    fi
  done
}

stop_ollama_server() {
  if pgrep -f "ollama serve" >/dev/null; then
    echo "  ↓ Ollama 서버 종료 중..."
    pkill -f "ollama serve" 2>/dev/null || true
    sleep 1
    if pgrep -f "ollama serve" >/dev/null; then
      pkill -9 -f "ollama serve" 2>/dev/null || true
    fi
    echo "  ✓ Ollama 서버 종료됨"
  else
    echo "  (Ollama 서버 안 떠 있음)"
  fi

  # macOS Ollama.app 도 종료 (선택)
  if pgrep -f "Ollama.app" >/dev/null 2>&1; then
    echo "  ↓ Ollama.app 종료 중..."
    osascript -e 'quit app "Ollama"' 2>/dev/null || true
    echo "  ✓ Ollama.app 종료됨"
  fi
}

mode="models"
target=""
case "${1:-}" in
  --server|--all) mode="all" ;;
  --help|-h)
    sed -n '2,18p' "$0"
    exit 0
    ;;
  "") ;;
  *)  target="$1" ;;
esac

echo "🧹 모델 메모리 정리"
echo "─────────────────────────────"
echo "[Ollama 로드된 모델]"
stop_ollama_models "$target"
echo ""
echo "[MLX 프로세스]"
stop_mlx_processes

if [[ "$mode" == "all" ]]; then
  echo ""
  echo "[Ollama 서버]"
  stop_ollama_server
fi

echo ""
echo "✅ 완료. 메모리 사용량 확인:"
echo "   sysctl -n hw.memsize | awk '{printf \"총: %.0fGB\\n\", \$1/1024/1024/1024}'"
echo "   vm_stat | head -5"
