#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
#  EXAONE 4.0 1.2B  (Ollama / GGUF Q4_K_M)
# ─────────────────────────────────────────────────────────────────────────────
#  • 개발사   : LG AI연구원 (LG AI Research, 한국)
#  • 공개일   : 2025년 (EXAONE 4.0 시리즈, 32B / 1.2B 동시 공개)
#  • 파라미터 : 1.2B (경량) — 동일 시리즈에 32B Hybrid Attention 모델 존재
#  • 라이선스 : EXAONE AI Model License (연구·개인 사용 무료, 상업용 별도)
#  • 언어     : 한국어 / 영어 / 스페인어 (다국어 학습)
#  • 특징
#     - "Hybrid Reasoning" 아키텍처: 일반 응답 + Chain-of-Thought 추론 동시 지원
#     - 1.2B 모델임에도 GPT-4o mini 대비 수학/코딩/과학 벤치마크에서 우위
#     - 한국 정부 "독자 AI 파운데이션 모델(독파모)" 사업 후보 모델
#     - LG가 자체 슈퍼컴 인프라로 학습한 자체 개발 한국 소버린 AI
#  • 메모리   : ~0.8 GB (Q4_K_M 양자화)
#  • 백엔드   : Ollama (llama.cpp 기반 GGUF)
# ─────────────────────────────────────────────────────────────────────────────
#  Usage:
#    exaone              # 대화형 (종료: /bye)
#    exaone "질문"        # 단발성 응답
# ─────────────────────────────────────────────────────────────────────────────
set -e
MODEL="hf.co/LGAI-EXAONE/EXAONE-4.0-1.2B-GGUF:Q4_K_M"
if [[ $# -gt 0 ]]; then
  ollama run "$MODEL" "$*"
else
  echo "▶ EXAONE 4.0 1.2B (LG AI연구원) — 종료: /bye"
  ollama run "$MODEL"
fi
